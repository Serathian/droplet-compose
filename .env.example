# Your GitHub username (used to pull images from GHCR)
GITHUB_OWNER=Serathian

# Email for Let's Encrypt certificate registration
ACME_EMAIL=your@email.com

# Traefik dashboard basic auth (generate with: docker run --rm httpd:alpine htpasswd -nB admin | sed -e 's/\$/\$\$/g')
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$changeme

# CMS — Payload secret (JWT signing)
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=change-me-to-32-plus-random-hex-characters

# CMS — PostgreSQL (cms-db)
CMS_DB_NAME=payload
CMS_DB_USER=payload
CMS_DB_PASSWORD=change-me-to-a-strong-password

# Legacy MySQL / WordPress credentials (services removed; kept until WP content is migrated)
# MYSQL_ROOT_PASSWORD=change-me-strong-root-password
# MYSQL_DATABASE=wordpress
# MYSQL_USER=wordpress
# MYSQL_PASSWORD=change-me-strong-password

# jake-reddy.com backend env vars
# SMTP credentials for nodemailer (contact form)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
CONTACT_TO_EMAIL=your@email.com
# reCAPTCHA secret key
RECAPTCHA_SECRET=your-recaptcha-secret
